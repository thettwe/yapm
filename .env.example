# yapm environment — copy to .env and edit. Every value below has a working
# default baked into the compose files, so `docker compose -f docker/docker-compose.yml up -d`
# runs with an empty .env for a localhost deploy. Override what you need for production.
#
# Compose reads .env from the directory you run it in. Run compose from the repo root:
#   docker compose --env-file .env -f docker/docker-compose.yml up -d
# (or `cp .env.example .env` and run from the repo root).

# ── Postgres ────────────────────────────────────────────────────────────────
# Single source of truth for the database credentials. The app's DATABASE_URL and
# zero-cache's ZERO_UPSTREAM_DB / ZERO_CVR_DB / ZERO_CHANGE_DB are derived from these
# inside the compose files, so you set them in exactly one place.
POSTGRES_USER=yapm
POSTGRES_PASSWORD=yapm            # CHANGE THIS in production.
POSTGRES_DB=yapm

# ── App container (yapm: API + Zero endpoints + built SPA) ───────────────────
# Host port the app is published on. The app always listens on 3000 inside its network.
YAPM_HOST_PORT=3000
# pino log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info
# node-postgres pool ceiling for the app.
DATABASE_POOL_MAX=10
# Name of the workspace row seeded on first boot against an empty database.
SEED_WORKSPACE_NAME=yapm
# Prebuilt image to run instead of building locally, e.g. ghcr.io/<org>/yapm:edge.
# Leave unset to build from docker/Dockerfile on `docker compose up`.
# YAPM_IMAGE=yapm:local

# ── zero-cache ───────────────────────────────────────────────────────────────
# Host port zero-cache is published on. The browser connects DIRECTLY to this
# origin over WebSocket, so it must be reachable from the user's browser.
ZERO_CACHE_HOST_PORT=4848
# Guards the zero-cache inspector and /statz. Required by zero-cache outside
# NODE_ENV=development. CHANGE THIS in production.
ZERO_ADMIN_PASSWORD=change-me-in-production
# Pin a different zero-cache image if needed. Must match the @rocicorp/zero
# catalog version so wire protocol and schema shape agree.
# ZERO_IMAGE=rocicorp/zero:1.8.0

# ── zero-cache ⇄ app endpoint auth (shared secret, X-Api-Key) ────────────────
# zero-cache sends these to the app's /api/zero/query and /api/zero/mutate; the app
# rejects any request whose header does not match. Both containers read the same
# variable, so they can never disagree. CHANGE THESE in production.
ZERO_QUERY_API_KEY=yapm-zero-query-key-change-me
ZERO_MUTATE_API_KEY=yapm-zero-mutate-key-change-me

# ── Authentication (better-auth, in-process — adds NO container) ─────────────
# Signing secret for sessions and the Zero sync JWT. CHANGE THIS in production
# (e.g. `openssl rand -base64 32`). An empty .env still boots with the insecure default.
BETTER_AUTH_SECRET=yapm-dev-secret-change-me-in-production
# The browser-facing URL of the app. OAuth callbacks and the sync token's issuer/audience
# use it. Set to your real origin when serving from a domain or a non-3000 host port.
BETTER_AUTH_URL=http://localhost:3000
# The SPA's browser origin, trusted for CORS and better-auth. In production the SPA is
# served same-origin by the app; in dev it is Vite on http://localhost:5173.
WEB_ORIGIN=http://localhost:3000
# GitHub OAuth (all methods are free, none gated). Leave BOTH unset to disable GitHub
# sign-in — an unconfigured provider is simply absent, never paywalled.
# Callback URL to register: ${BETTER_AUTH_URL}/api/auth/callback/github
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# OIDC/SSO is free and enabled; providers are registered at runtime via the SSO plugin,
# so there is no static OIDC env to set here.
# The first authenticated user becomes the workspace admin. Set this to bind that to a
# specific verified email; others then wait for an invite. Leave unset for first-user-wins.
# YAPM_BOOTSTRAP_ADMIN_EMAIL=
# Outbound email for verification / invite delivery. Email verification is OFF by default,
# so this is optional; unset disables email (invite links are always copyable).
# SMTP_URL=smtp://user:pass@host:587

# ── Build-time (baked into the SPA at image build) ───────────────────────────
# The zero-cache origin the browser is told to connect to. Baked into the web bundle
# by Vite at build time, so it must be the browser-reachable URL — not an in-network
# hostname. Change it (and rebuild the image) when serving from a real host/domain,
# e.g. https://zero.example.com.
VITE_ZERO_CACHE_URL=http://localhost:4848

# ── Development loop only (docker/docker-compose.dev.yml + `pnpm dev`) ────────
# Host port the dev Postgres is published on (the host-run server connects here).
POSTGRES_HOST_PORT=5440
