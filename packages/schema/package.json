{
  "name": "@yapm/schema",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "default": "./dist/db/index.js"
    },
    "./server": {
      "types": "./dist/zero/server-mutators.d.ts",
      "default": "./dist/zero/server-mutators.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rocicorp/zero": "catalog:",
    "fractional-indexing": "catalog:",
    "kysely": "catalog:",
    "pg": "catalog:",
    "uuidv7": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@yapm/config": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
