{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": [
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "packages/config/tsconfig/*.json",
    "packages/config/biome.base.json"
  ],
  "globalEnv": ["NODE_ENV"],
  "ui": "stream",
  "remoteCache": {
    "enabled": false
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.*", "!e2e/**"],
      "outputs": ["dist/**"],
      "env": ["VITE_*"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "DATABASE_URL",
        "DATABASE_POOL_MAX",
        "HOST",
        "LOG_LEVEL",
        "PORT",
        "SEED_WORKSPACE_NAME",
        "SERVER_ORIGIN",
        "VITE_ZERO_CACHE_URL",
        "WEB_DIST_DIR",
        "ZERO_MUTATE_API_KEY",
        "ZERO_QUERY_API_KEY"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "//#lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "passThroughEnv": ["DATABASE_URL", "CI"]
    },
    "e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": ["playwright-report/**"],
      "passThroughEnv": [
        "DATABASE_URL",
        "CI",
        "E2E_SERVER_PORT",
        "E2E_WEB_PORT",
        "E2E_ZERO_CACHE_URL"
      ]
    }
  }
}
